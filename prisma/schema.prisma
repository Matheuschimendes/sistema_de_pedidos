generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DeliveryType {
  delivery
  pickup
}

enum PaymentMethod {
  pix
  credit
  debit
  cash
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  completed
  canceled
}

model Restaurant {
  id              String      @id @default(cuid())
  slug            String      @unique
  name            String
  description     String?
  highlight       String?
  logoUrl         String?
  bannerImageUrl  String?
  whatsappNumber  String?
  timeZone        String      @default("America/Fortaleza")
  openingHours    Json?
  deliveryFee     Decimal     @default(5) @db.Decimal(10, 2)
  deliveryTime    String?
  rating          Float?
  reviewCount     Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  products        Product[]
  categories      Category[]
  adminUsers      AdminUser[]
  orders          Order[]
}

model Category {
  id           String      @id @default(cuid())
  name         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model AdminUser {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
}

model Product {
  id             Int        @id @default(autoincrement())
  name           String
  description    String
  price          Decimal    @db.Decimal(10, 2)
  imageUrl       String
  category       String
  additionalInfo String?
  isAvailable    Boolean    @default(true)
  badge          String?
  featured       Boolean    @default(false)
  emoji          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, category])
  @@index([restaurantId, isAvailable])
  @@unique([restaurantId, name, category])
}

model Order {
  id              String        @id @default(cuid())
  status          OrderStatus   @default(pending)
  deliveryType    DeliveryType
  paymentMethod   PaymentMethod
  customerName    String
  customerPhone   String
  customerAddress String?
  customerNotes   String?
  subtotal        Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  restaurantId    String
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items           OrderItem[]

  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
}

model OrderItem {
  id          String   @id @default(cuid())
  productId   Int?
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}
